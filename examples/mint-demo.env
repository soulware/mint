# 1Password secret references for `mint serve`'s admin credential.
#
# `mint serve` reads its Tigris/S3 admin credential from the standard AWS
# environment variables (AdminCredential::from_env) — never from the TOML.
# This file holds 1Password *references* (op://vault/item/field), not the
# secrets themselves, so it is safe to commit. `op run` resolves them at
# launch and injects the real values into mint's process environment only:
#
#   cp examples/mint-demo.env ./mint-demo.env   # then edit refs for your vault
#   export MINT_CONFIG=./mint-demo.toml
#   op run --env-file ./mint-demo.env -- ./target/release/mint serve
#
# Only `serve` touches IAM; the operator/client subcommands do not need this.
# Point the refs at the same admin credential you use elsewhere.

AWS_ACCESS_KEY_ID=op://elide/tigris-elide-dev/access_key_id
AWS_SECRET_ACCESS_KEY=op://elide/tigris-elide-dev/secret_access_key

# STS-style temporary credentials also carry a session token — uncomment if
# your admin credential is temporary (read by AdminCredential::from_env too):
# AWS_SESSION_TOKEN=op://elide/tigris-elide-dev/session_token
