{
  "Version": "2012-10-17",
  "Statement": [{
    "Sid": "DemoAttested",
    "Effect": "Allow",
    "Action": ["s3:GetObject"],
    "Resource": ["arn:aws:s3:::{{env.bucket}}/{{env.prefix}}/{{caveat.sub}}/{{caveat.dir}}/*"],
    "Condition": {
      "DateLessThan": {"aws:CurrentTime": "{{mint.expiry}}"}
    }
  }]
}
