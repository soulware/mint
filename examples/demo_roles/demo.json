{
  "Version": "2012-10-17",
  "Statement": [{
    "Sid": "DemoPlain",
    "Effect": "Allow",
    "Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject"],
    "Resource": ["arn:aws:s3:::{{env.bucket}}/{{env.prefix}}/*"],
    "Condition": {
      "DateLessThan": {"aws:CurrentTime": "{{mint.expiry}}"}
    }
  }]
}
