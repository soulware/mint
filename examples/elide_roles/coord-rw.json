{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "NamesReadWriteDelete",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject"],
      "Resource": ["arn:aws:s3:::{{env.bucket}}/names/*"],
      "Condition": {
        "DateLessThan": {"aws:CurrentTime": "{{mint.expiry}}"}
      }
    },
    {
      "Sid": "EventsAppendOnly",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject"],
      "Resource": ["arn:aws:s3:::{{env.bucket}}/events/*"],
      "Condition": {
        "DateLessThan": {"aws:CurrentTime": "{{mint.expiry}}"}
      }
    },
    {
      "Sid": "OwnIdentityImmutable",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject"],
      "Resource": ["arn:aws:s3:::{{env.bucket}}/coordinators/{{caveat.sub}}/*"],
      "Condition": {
        "DateLessThan": {"aws:CurrentTime": "{{mint.expiry}}"}
      }
    },
    {
      "Sid": "MetaIdentityEstablishment",
      "Effect": "Allow",
      "Action": ["s3:PutObject"],
      "Resource": ["arn:aws:s3:::{{env.bucket}}/meta/*"],
      "Condition": {
        "DateLessThan": {"aws:CurrentTime": "{{mint.expiry}}"}
      }
    }
  ]
}
