{
  "Version": "2012-10-17",
  "Statement": [{
    "Sid": "ReadWriteSingleVolume",
    "Effect": "Allow",
    "Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject"],
    "Resource": [
      "arn:aws:s3:::{{env.bucket}}/by_id/{{attested.volume}}/*"
    ],
    "Condition": {
      "DateLessThan": {"aws:CurrentTime": "{{mint.expiry}}"}
    }
  }]
}
